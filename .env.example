# Copy this file to .env and fill in your values

# The secret URL path — only people with the full URL can access the form
# Generate one with: openssl rand -hex 8
SECRET_PATH=your_secret_here

# Port the server listens on (3000 is fine behind nginx)
PORT=3000

# Google Drive folder ID for the "Ausgaben" folder
DRIVE_AUSGABEN_FOLDER_ID=

# Google Spreadsheet ID for "Expenses 26"
SHEET_ID=

# Sheet tab name within the spreadsheet
SHEET_TAB=Expenses

# Google Spreadsheet ID for the "Kontodaten" IBAN lookup
KONTODATEN_SHEET_ID=
